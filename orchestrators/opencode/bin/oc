#!/usr/bin/env bash
# oc — OpenCode launcher for forge
#
# Points OpenCode at the framework's opencode.jsonc config and the
# .opencode/ wrapper dir via OPENCODE_CONFIG / OPENCODE_CONFIG_DIR.
#
# FRAMEWORK_DIR resolution priority (analog to cc):
#   1. env var (override, e.g. testing alternate checkout)
#   2. install-time substitution (FRAMEWORK_DIR_INSTALLED below — set by
#      setup-oc.sh when this file is copied to ~/.local/bin/oc)
#   3. autodetect from $0 location (works only when run from source tree;
#      $0/../../../ resolves to /home for the installed copy — that's why
#      install-time substitution exists)
#
# Usage:
#   oc                # OpenCode with framework config
#   oc <opencode-args>

set -euo pipefail

# Install-time substitution marker. Empty value = source-tree run; setup-oc.sh
# overwrites this line when it installs oc to ~/.local/bin/. Do not edit by
# hand — change it via setup-oc.sh re-run.
FRAMEWORK_DIR_INSTALLED=""  # SUBSTITUTED-BY-SETUP-OC

if [ -z "${FRAMEWORK_DIR:-}" ]; then
  if [ -n "$FRAMEWORK_DIR_INSTALLED" ]; then
    FRAMEWORK_DIR="$FRAMEWORK_DIR_INSTALLED"
  else
    FRAMEWORK_DIR="$(cd "$(dirname "$(readlink -f "$0")")/../../.." && pwd)"
  fi
fi
export FRAMEWORK_DIR

OC_CONFIG_DIR="$FRAMEWORK_DIR/orchestrators/opencode/.opencode"
OC_CONFIG="$FRAMEWORK_DIR/orchestrators/opencode/opencode.jsonc"

# Verify config exists. If not, hint at setup-oc.sh.
if [ ! -f "$OC_CONFIG" ]; then
  echo "oc: ERROR — $OC_CONFIG not found." >&2
  echo "    Run: bash $FRAMEWORK_DIR/scripts/setup-oc.sh" >&2
  exit 1
fi

export OPENCODE_CONFIG_DIR="$OC_CONFIG_DIR"
export OPENCODE_CONFIG="$OC_CONFIG"

if ! command -v opencode &>/dev/null; then
  echo "oc: WARNUNG — 'opencode' nicht im PATH." >&2
fi

exec opencode "$@"
